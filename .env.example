# Mathom configuration — copy to .env and adjust.
# Every value has a sensible default; the stack runs with an empty .env.

# Host port the web UI is published on.
MATHOM_PORT=8080

# Ollama model used for summaries and follow-up chat.
# Pull it once with: make models   (or scripts/pull-model.sh)
OLLAMA_MODEL=llama3.2

# Ollama container image. Pinned by default for reproducibility; override to
# track a newer release.
# OLLAMA_IMAGE=ollama/ollama:0.32.1

# faster-whisper model size: tiny, base, small, medium, large-v3
WHISPER_MODEL=small

# cpu (default) or cuda when using compose.gpu.yaml
WHISPER_DEVICE=cpu

# int8 is fast on CPU; float16 recommended on GPU
WHISPER_COMPUTE_TYPE=int8

# Maximum upload size for a single recording, in megabytes.
MAX_UPLOAD_MB=200

# Per-client request rate limiting (in-process; protects the box and the login
# from runaway clients / brute force). Set MATHOM_RATE_LIMIT_ENABLED=false only
# if you front Mathom with another limiter.
# MATHOM_RATE_LIMIT_ENABLED=true
# MATHOM_RATE_LIMIT_PER_MINUTE=120         # cheap GET reads
# MATHOM_RATE_LIMIT_HEAVY_PER_MINUTE=20    # uploads, chat, summaries, search, login

# ─────────────────────────────────────────────────────────────────────────────
# Optional user management + Authentik SSO
# ─────────────────────────────────────────────────────────────────────────────
# Everything below is OFF by default. Leave AUTH_ENABLED=false to run Mathom as
# the original single-user local archive (no login). See docs/authentication.md.

# Turn on multi-user mode with Authentik single sign-on.
AUTH_ENABLED=false

# Set to false only if you serve Mathom over plain HTTP (not recommended).
SESSION_COOKIE_SECURE=true

# Public origin users reach Mathom on, used to build the OAuth redirect URI.
# e.g. https://mathom.example.com
PUBLIC_BASE_URL=

# The email address that becomes the archive Owner on first sign-in. Leave
# empty to make the very first user to sign in the Owner.
AUTH_OWNER_EMAIL=

# Authentik OIDC provider connection. These seed the settings; the Owner can
# adjust them later under "Sign-in" in the UI.
# Issuer is the provider URL, ending in /application/o/<app-slug>/
AUTHENTIK_ISSUER=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_SCOPES=openid profile email
