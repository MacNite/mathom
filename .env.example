# Mathom configuration — copy to .env and adjust.
# Every value has a sensible default; the stack runs with an empty .env.

# Host interface + port the web UI is published on.
# MATHOM_BIND defaults to 127.0.0.1 (loopback only) because auth is off by
# default. For LAN access set MATHOM_BIND=0.0.0.0 — but only behind a VPN or an
# authenticating reverse proxy, or with Authentik SSO enabled.
MATHOM_BIND=127.0.0.1
MATHOM_PORT=8080

# Ollama model used for summaries and follow-up chat.
# Pull it once with: make models   (or scripts/pull-model.sh)
OLLAMA_MODEL=llama3.2

# Ollama's base URL and per-request deadline. Set OLLAMA_BASE_URL when Ollama
# runs in another Compose stack or a private network, e.g. http://ollama-ai:11434.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_TIMEOUT_SECONDS=300

# Ollama container image. Pinned by default for reproducibility; override to
# track a newer release.
# OLLAMA_IMAGE=ollama/ollama:0.32.1

# faster-whisper model size: tiny, base, small, medium, large-v3
WHISPER_MODEL=small

# cpu (default) or cuda when using compose.gpu.yaml
WHISPER_DEVICE=cpu

# int8 is fast on CPU; float16 recommended on GPU
WHISPER_COMPUTE_TYPE=int8

# Optional names, jargon, and acronyms to bias faster-whisper.
MATHOM_WHISPER_INITIAL_PROMPT=
# Map-reduce summaries above this many transcript characters.
MATHOM_SUMMARY_CHUNK_CHARS=24000
# Optional diarization hook; defaults to no-op with no extra model dependency.
MATHOM_DIARIZATION_ENABLED=false

# Maximum upload size for a single recording, in megabytes.
MAX_UPLOAD_MB=200

# Admission control for background recording work. New uploads receive 503
# (with Retry-After) when this many jobs are already waiting.
MAX_QUEUED_JOBS=25

# Maximum simultaneous follow-up chat requests sent to Ollama.
CHAT_CONCURRENCY=1

# Per-client request rate limiting (in-process; protects the box and the login
# from runaway clients / brute force). Set MATHOM_RATE_LIMIT_ENABLED=false only
# if you front Mathom with another limiter.
# MATHOM_RATE_LIMIT_ENABLED=true
# MATHOM_RATE_LIMIT_PER_MINUTE=120         # cheap GET reads
# MATHOM_RATE_LIMIT_HEAVY_PER_MINUTE=20    # uploads, chat, summaries, search, login

# ─────────────────────────────────────────────────────────────────────────────
# Optional local user management + Authentik SSO
# ─────────────────────────────────────────────────────────────────────────────
# Everything below is OFF by default. Leave AUTH_ENABLED=false to run Mathom as
# the original single-user local archive (no login). See docs/authentication.md.

# Turn on Mathom-managed local accounts (first start creates an admin).
# AUTH_ENABLED is retained as Compose-friendly compatibility name.
AUTH_ENABLED=false
# Equivalent direct backend setting when not using Compose: MATHOM_AUTH_ENABLED=true

# Set to false only if you serve Mathom over plain HTTP (not recommended).
SESSION_COOKIE_SECURE=true

# Absolute session lifetime in hours before users must sign in again.
SESSION_TTL_HOURS=336

# Public origin users reach Mathom on, used to build the OAuth redirect URI.
# e.g. https://mathom.example.com
PUBLIC_BASE_URL=

# No environment default administrator exists; use first-start onboarding.

# Optional Authentik OIDC provider. Local login remains available without it;
# an administrator can configure it later under Sign-in settings.
# Issuer is the provider URL, ending in /application/o/<app-slug>/
AUTHENTIK_ISSUER=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_SCOPES=openid profile email
